<Window x:Class="RewiredManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewired" Height="720" Width="1040" MinWidth="900" MinHeight="600">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SteamBgDeep}" BorderBrush="{StaticResource SteamBorder}"
                BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Rewired" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SteamAccent}" />
                <TextBlock Style="{StaticResource RewiredSubtitle}"
                           Text="Unlock stack · add games · launch Steam — Rewired desktop control plane."
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="System">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource RewiredSectionTitle}" Text="Steam &amp; unlock" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Steam path" VerticalAlignment="Center" Foreground="{StaticResource SteamTextSecondary}" />
                            <TextBox Grid.Column="1" x:Name="SteamPathBox" Margin="8,0" />
                            <Button Grid.Column="2" Content="Save" Click="SaveConfig_Click" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Unlock backend" VerticalAlignment="Center" Foreground="{StaticResource SteamTextSecondary}" />
                            <ComboBox Grid.Column="1" x:Name="BackendCombo" Margin="8,0" />
                        </Grid>
                        <TextBlock x:Name="UnlockStatusText" TextWrapping="Wrap" Foreground="{StaticResource SteamTextSecondary}" Margin="0,8,0,12" />

                        <WrapPanel Margin="0,0,0,12">
                            <Button Style="{StaticResource RewiredPrimaryButton}" Content="Launch Steam" Margin="0,0,8,8"
                                    Click="LaunchSteam_Click"
                                    ToolTip="Start Steam with the Rewired stack loaded." />
                            <Button Content="Set up Rewired" Margin="0,0,8,8" Click="SetupWizard_Click" />
                            <Button Content="Refresh status" Margin="0,0,8,8" Click="RefreshUnlock_Click" />
                            <Button Content="Install OpenSteamTool" Margin="0,0,8,8" Click="InstallOst_Click" />
                            <Button Content="Check for updates" Margin="0,0,8,8" Click="CheckUpdates_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap" Foreground="{StaticResource SteamTextMuted}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource RewiredSubtitle}" x:Name="SharedConfigPathText" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Add game">
                <StackPanel Margin="14">
                    <TextBlock Style="{StaticResource RewiredSectionTitle}" Text="Add via Ryuu" />
                    <TextBlock Style="{StaticResource RewiredSubtitle}"
                               Text="Writes .lua to the unlock directory and manifests to depotcache. Requires Ryuu session in Secrets."
                               Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AppID" VerticalAlignment="Center" Foreground="{StaticResource SteamTextSecondary}" />
                        <TextBox Grid.Column="1" x:Name="AppIdBox" />
                        <Button Grid.Column="2" Style="{StaticResource RewiredPrimaryButton}"
                                Content="Download &amp; install" Margin="12,0,0,0" Click="AddGame_Click" />
                    </Grid>
                    <TextBlock x:Name="AddGameResultText" TextWrapping="Wrap" Foreground="{StaticResource SteamTextSecondary}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Secrets">
                <StackPanel Margin="14">
                    <TextBlock Style="{StaticResource RewiredSectionTitle}" Text="Plugin secrets" />
                    <TextBlock Style="{StaticResource RewiredSubtitle}"
                               Text="Stored in the live plugin tree (gitignored). Values stay on disk; they are not logged."
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="SecretsPathText" Foreground="{StaticResource SteamTextMuted}" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <TextBlock Text="Ryuu session cookie" Foreground="{StaticResource SteamTextSecondary}" Margin="0,0,0,4" />
                    <TextBox x:Name="RyuuSessionBox" Margin="0,0,0,12" />

                    <TextBlock Text="ManifestHub API key" Foreground="{StaticResource SteamTextSecondary}" Margin="0,0,0,4" />
                    <TextBox x:Name="ManifestHubKeyBox" Margin="0,0,0,12" />

                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="Load" Margin="0,0,8,8" Click="LoadSecrets_Click" />
                        <Button Style="{StaticResource RewiredPrimaryButton}" Content="Save secrets" Margin="0,0,8,8" Click="SaveSecrets_Click" />
                        <Button Content="Test Ryuu" Margin="0,0,8,8" Click="TestRyuu_Click" />
                        <Button Content="Test ManifestHub" Margin="0,0,8,8" Click="TestManifestHub_Click" />
                    </WrapPanel>
                    <TextBlock x:Name="SecretsResultText" TextWrapping="Wrap" Foreground="{StaticResource SteamTextSecondary}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Plugin">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Plugin path" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource SteamTextSecondary}" />
                        <TextBox Grid.Column="1" x:Name="PluginPathBox" />
                        <Button Grid.Column="2" Content="Inspect" Margin="10,0,0,0" Click="Inspect_Click" />
                        <Button Grid.Column="3" Content="Probe sources" Margin="10,0,0,0" Click="Probe_Click" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource RewiredPanel}" Margin="0,0,12,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="PluginStatusText" Text="Not inspected." TextWrapping="Wrap" Foreground="{StaticResource SteamTextSecondary}" />
                            </ScrollViewer>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource RewiredPanel}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Source health" FontWeight="SemiBold" Foreground="{StaticResource SteamAccent}" Margin="0,0,0,8" />
                                <ListBox x:Name="ProbeResultsList" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Deploy">
                <StackPanel Margin="14">
                    <TextBlock Style="{StaticResource RewiredSectionTitle}" Text="Deploy plugin from repo" />
                    <TextBlock Style="{StaticResource RewiredSubtitle}"
                               Text="Runs deploy.ps1 (backup-preserving). Steam should be closed for Millennium runtime updates."
                               Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Repo root" VerticalAlignment="Center" Foreground="{StaticResource SteamTextSecondary}" />
                        <TextBox Grid.Column="1" x:Name="RepoRootBox" />
                    </Grid>
                    <Button Style="{StaticResource RewiredPrimaryButton}" Content="Deploy Rewired plugin" HorizontalAlignment="Left" Click="Deploy_Click" />
                    <TextBox x:Name="DeployLogBox" Margin="0,12,0,0" MinHeight="200" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" IsReadOnly="True" Padding="8" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="Ready." Foreground="{StaticResource SteamTextMuted}" Margin="0,10,0,0" />
    </Grid>
</Window>
