<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SteamBgPrimaryColor">#1b2838</Color>
    <Color x:Key="SteamBgSecondaryColor">#2a475e</Color>
    <Color x:Key="SteamBgDeepColor">#0e1419</Color>
    <Color x:Key="SteamBgInputColor">#16202d</Color>
    <Color x:Key="SteamBgElevatedColor">#1a2a38</Color>
    <Color x:Key="SteamAccentColor">#66c0f4</Color>
    <Color x:Key="SteamAccentHoverColor">#7dd4ff</Color>
    <Color x:Key="SteamBorderColor">#3d5a73</Color>
    <Color x:Key="SteamBorderSubtleColor">#2a3f52</Color>
    <Color x:Key="SteamTextPrimaryColor">#ffffff</Color>
    <Color x:Key="SteamTextSecondaryColor">#acb2b8</Color>
    <Color x:Key="SteamTextMutedColor">#8f98a0</Color>
    <Color x:Key="SteamSuccessColor">#5ba32b</Color>
    <Color x:Key="SteamWarnColor">#e8a020</Color>
    <Color x:Key="SteamDangerColor">#d94126</Color>

    <SolidColorBrush x:Key="SteamBgPrimary" Color="{StaticResource SteamBgPrimaryColor}" />
    <SolidColorBrush x:Key="SteamBgSecondary" Color="{StaticResource SteamBgSecondaryColor}" />
    <SolidColorBrush x:Key="SteamBgDeep" Color="{StaticResource SteamBgDeepColor}" />
    <SolidColorBrush x:Key="SteamBgInput" Color="{StaticResource SteamBgInputColor}" />
    <SolidColorBrush x:Key="SteamBgElevated" Color="{StaticResource SteamBgElevatedColor}" />
    <SolidColorBrush x:Key="SteamAccent" Color="{StaticResource SteamAccentColor}" />
    <SolidColorBrush x:Key="SteamAccentHover" Color="{StaticResource SteamAccentHoverColor}" />
    <SolidColorBrush x:Key="SteamBorder" Color="{StaticResource SteamBorderColor}" />
    <SolidColorBrush x:Key="SteamBorderSubtle" Color="{StaticResource SteamBorderSubtleColor}" />
    <SolidColorBrush x:Key="SteamTextPrimary" Color="{StaticResource SteamTextPrimaryColor}" />
    <SolidColorBrush x:Key="SteamTextSecondary" Color="{StaticResource SteamTextSecondaryColor}" />
    <SolidColorBrush x:Key="SteamTextMuted" Color="{StaticResource SteamTextMutedColor}" />
    <SolidColorBrush x:Key="SteamSuccess" Color="{StaticResource SteamSuccessColor}" />
    <SolidColorBrush x:Key="SteamWarn" Color="{StaticResource SteamWarnColor}" />
    <SolidColorBrush x:Key="SteamDanger" Color="{StaticResource SteamDangerColor}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SteamBgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SteamBgInput}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="CaretBrush" Value="{StaticResource SteamAccent}" />
        <Setter Property="SelectionBrush" Value="#33446688" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SteamBgInput}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SteamBgSecondary}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#35556f" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource SteamAccent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1f3447" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RewiredPrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#75c9f7" Offset="0" />
                    <GradientStop Color="#4a9ece" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#0a1218" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="#8ed8ff" />
    </Style>

    <Style x:Key="RewiredGhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
    </Style>

    <Style x:Key="RewiredPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SteamBgElevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="RewiredCard" TargetType="Border" BasedOn="{StaticResource RewiredPanel}">
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="MinHeight" Value="88" />
    </Style>

    <Style x:Key="RewiredSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="RewiredPageSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,20" />
    </Style>

    <Style x:Key="RewiredSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="RewiredFieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="RewiredStatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="RewiredStatValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
    </Style>

    <Style x:Key="RewiredNavItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="10,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                            Padding="14,11" Margin="0,1"
                            BorderThickness="3,0,0,0" BorderBrush="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1a2a38" />
                            <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1e3344" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource SteamAccent}" />
                            <Setter Property="Foreground" Value="{StaticResource SteamAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RewiredNavList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,8" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource RewiredNavItem}" />
    </Style>

    <Style x:Key="RewiredLogBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

</ResourceDictionary>
