<Window x:Class="RewiredManager.App.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Set up Rewired" Height="560" Width="700" MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanMinimize"
        Background="{StaticResource SteamBgPrimary}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{StaticResource SteamTextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SteamBgDeep}" Padding="28,28"
                BorderBrush="{StaticResource SteamBorderSubtle}" BorderThickness="0,0,0,1"
                materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel>
                <TextBlock Text="Set up Rewired" Style="{StaticResource RewiredSectionTitle}" />
                <TextBlock Style="{StaticResource RewiredPageSubtitle}" Margin="0"
                           Text="Install unlock backend, Millennium plugin, then launch Steam from Rewired." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="560">
                <TextBlock Style="{StaticResource RewiredFieldLabel}" Text="Steam folder" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SteamPathBox" />
                    <Button Grid.Column="1" Style="{StaticResource RewiredGhostButton}"
                            Content="Detect" Margin="12,0,0,0" Click="DetectSteam_Click" />
                </Grid>
                <TextBlock x:Name="ReadinessText" TextWrapping="Wrap"
                           Foreground="{StaticResource SteamTextMuted}" Margin="0,0,0,20" />

                <Border Style="{StaticResource RewiredPanel}" Margin="0,0,0,16">
                    <StackPanel>
                        <CheckBox x:Name="InstallUiCheck" Content="Install in-Steam UI (Millennium + Rewired plugin)" IsChecked="True" />
                        <CheckBox x:Name="InstallOstCheck" Content="Install OpenSteamTool (unlock backend)" IsChecked="True" />
                        <CheckBox x:Name="ShortcutCheck" Content="Create Desktop shortcut" IsChecked="True" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource RewiredPanel}" Padding="0">
                    <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" MaxHeight="180">
                        <TextBlock x:Name="LogText" TextWrapping="Wrap"
                                   Foreground="{StaticResource SteamTextSecondary}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="16" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource SteamBgDeep}" Padding="28,18"
                BorderBrush="{StaticResource SteamBorderSubtle}" BorderThickness="0,1,0,0">
            <WrapPanel HorizontalAlignment="Right">
                <Button x:Name="LaunchSteamButton" Style="{StaticResource RewiredPrimaryButton}"
                        Content="Launch Steam" Margin="0,0,10,0" Visibility="Collapsed" Click="LaunchSteam_Click" />
                <Button Style="{StaticResource RewiredGhostButton}" Content="Close"
                        Margin="0,0,10,0" Click="Close_Click" />
                <Button x:Name="RunButton" Style="{StaticResource RewiredPrimaryButton}"
                        Content="Install Rewired" Click="RunSetup_Click" />
            </WrapPanel>
        </Border>
    </Grid>
</Window>
