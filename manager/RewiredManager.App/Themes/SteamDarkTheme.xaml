<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Steam Original palette (LuaTools / STLT 1:1 dark) -->
    <Color x:Key="SteamBgPrimaryColor">#1b2838</Color>
    <Color x:Key="SteamBgSecondaryColor">#2a475e</Color>
    <Color x:Key="SteamBgDeepColor">#0e1419</Color>
    <Color x:Key="SteamBgInputColor">#16202d</Color>
    <Color x:Key="SteamAccentColor">#66c0f4</Color>
    <Color x:Key="SteamAccentHoverColor">#7dd4ff</Color>
    <Color x:Key="SteamBorderColor">#3d5a73</Color>
    <Color x:Key="SteamTextPrimaryColor">#ffffff</Color>
    <Color x:Key="SteamTextSecondaryColor">#acb2b8</Color>
    <Color x:Key="SteamTextMutedColor">#8f98a0</Color>

    <SolidColorBrush x:Key="SteamBgPrimary" Color="{StaticResource SteamBgPrimaryColor}" />
    <SolidColorBrush x:Key="SteamBgSecondary" Color="{StaticResource SteamBgSecondaryColor}" />
    <SolidColorBrush x:Key="SteamBgDeep" Color="{StaticResource SteamBgDeepColor}" />
    <SolidColorBrush x:Key="SteamBgInput" Color="{StaticResource SteamBgInputColor}" />
    <SolidColorBrush x:Key="SteamAccent" Color="{StaticResource SteamAccentColor}" />
    <SolidColorBrush x:Key="SteamAccentHover" Color="{StaticResource SteamAccentHoverColor}" />
    <SolidColorBrush x:Key="SteamBorder" Color="{StaticResource SteamBorderColor}" />
    <SolidColorBrush x:Key="SteamTextPrimary" Color="{StaticResource SteamTextPrimaryColor}" />
    <SolidColorBrush x:Key="SteamTextSecondary" Color="{StaticResource SteamTextSecondaryColor}" />
    <SolidColorBrush x:Key="SteamTextMuted" Color="{StaticResource SteamTextMutedColor}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SteamBgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SteamBgInput}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CaretBrush" Value="{StaticResource SteamAccent}" />
        <Setter Property="SelectionBrush" Value="#33445566" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SteamBgInput}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorder}" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SteamBgSecondary}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#35556f" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource SteamAccent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1f3447" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RewiredPrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#66c0f4" Offset="0" />
                    <GradientStop Color="#4a9ece" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#0e1419" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="#7dd4ff" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Background="Transparent" BorderThickness="0,0,0,2"
                            BorderBrush="Transparent" Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SteamAccent}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource SteamAccent}" />
                            <Setter TargetName="TabBorder" Property="Background" Value="#1a2836" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RewiredPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="RewiredSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamAccent}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="RewiredSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
