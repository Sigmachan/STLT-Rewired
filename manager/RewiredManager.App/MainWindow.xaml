<Window x:Class="RewiredManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewired Manager" Height="640" Width="980"
        Background="#10131a" Foreground="#f3f4f6">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="STLT Rewired Manager" FontSize="26" FontWeight="Bold" />
            <TextBlock Text="Ryuu-first companion shell for plugin discovery, source health, and future safe deploy/rollback flows."
                       Foreground="#9ca3af" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="#171b24" BorderBrush="#2f3848" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Plugin path" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#cbd5e1" />
                <TextBox Grid.Column="1" x:Name="PluginPathBox" MinWidth="420" Padding="8" Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                <Button Grid.Column="2" Content="Inspect" Padding="14,8" Margin="10,0,0,0" Click="Inspect_Click" />
                <Button Grid.Column="3" Content="Probe sources" Padding="14,8" Margin="10,0,0,0" Click="Probe_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171b24" BorderBrush="#2f3848" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Plugin status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock x:Name="PluginStatusText" Text="Not inspected yet." TextWrapping="Wrap" Foreground="#d1d5db" />
                    <Separator Margin="0,16" Background="#2f3848" />
                    <TextBlock Text="Safety" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Secrets are only shown as present/missing. Cookie/API key values are never printed."
                               TextWrapping="Wrap" Foreground="#9ca3af" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#171b24" BorderBrush="#2f3848" BorderThickness="1" CornerRadius="10" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Source health" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox x:Name="ProbeResultsList" Background="#0b0e14" BorderBrush="#3b4557" Foreground="#f3f4f6" />
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" x:Name="FooterText" Text="Ready." Foreground="#9ca3af" Margin="0,12,0,0" />
    </Grid>
</Window>
