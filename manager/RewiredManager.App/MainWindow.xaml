<Window x:Class="RewiredManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewired Manager" Height="720" Width="1040" MinWidth="900" MinHeight="600"
        Background="#10131a" Foreground="#f3f4f6">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Rewired Manager" FontSize="26" FontWeight="Bold" />
            <TextBlock Text="Production control plane — unlock backend, add games, optional Millennium plugin."
                       Foreground="#9ca3af" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <TabControl Grid.Row="1" Background="#171b24" BorderBrush="#2f3848">
            <!-- System -->
            <TabItem Header="System">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Steam &amp; unlock" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Steam path" VerticalAlignment="Center" Foreground="#cbd5e1" />
                            <TextBox Grid.Column="1" x:Name="SteamPathBox" Padding="8" Margin="8,0"
                                     Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                            <Button Grid.Column="2" Content="Save" Padding="12,8" Click="SaveConfig_Click" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Unlock backend" VerticalAlignment="Center" Foreground="#cbd5e1" />
                            <ComboBox Grid.Column="1" x:Name="BackendCombo" Margin="8,0" Padding="6"
                                      Background="#0b0e14" Foreground="#111827" />
                        </Grid>
                        <TextBlock x:Name="UnlockStatusText" TextWrapping="Wrap" Foreground="#d1d5db" Margin="0,8,0,12" />

                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Refresh status" Padding="14,8" Margin="0,0,8,8" Click="RefreshUnlock_Click" />
                            <Button Content="Install OpenSteamTool" Padding="14,8" Margin="0,0,8,8" Click="InstallOst_Click" />
                            <Button Content="Restart Steam" Padding="14,8" Margin="0,0,8,8" Click="RestartSteam_Click" />
                        </WrapPanel>

                        <TextBlock Text="Shared config" FontSize="14" Foreground="#9ca3af" TextWrapping="Wrap"
                                   x:Name="SharedConfigPathText" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Add game -->
            <TabItem Header="Add game">
                <StackPanel Margin="14">
                    <TextBlock Text="Add via Ryuu (Manager-native)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Writes .lua to the active unlock directory and manifests to depotcache. Requires Ryuu session in plugin secrets."
                               Foreground="#9ca3af" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AppID" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="AppIdBox" Padding="8" Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                        <Button Grid.Column="2" Content="Download &amp; install" Padding="14,8" Margin="12,0,0,0" Click="AddGame_Click" />
                    </Grid>
                    <TextBlock x:Name="AddGameResultText" TextWrapping="Wrap" Foreground="#d1d5db" />
                </StackPanel>
            </TabItem>

            <!-- Plugin -->
            <TabItem Header="Plugin (optional)">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Plugin path" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#cbd5e1" />
                        <TextBox Grid.Column="1" x:Name="PluginPathBox" Padding="8" Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                        <Button Grid.Column="2" Content="Inspect" Padding="14,8" Margin="10,0,0,0" Click="Inspect_Click" />
                        <Button Grid.Column="3" Content="Probe sources" Padding="14,8" Margin="10,0,0,0" Click="Probe_Click" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0b0e14" BorderBrush="#3b4557" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="PluginStatusText" Text="Not inspected." TextWrapping="Wrap" Foreground="#d1d5db" />
                            </ScrollViewer>
                        </Border>
                        <Border Grid.Column="1" Background="#0b0e14" BorderBrush="#3b4557" BorderThickness="1" CornerRadius="8" Padding="12">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Source health" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ListBox x:Name="ProbeResultsList" Background="#10131a" BorderThickness="0" Foreground="#f3f4f6" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Deploy -->
            <TabItem Header="Deploy">
                <StackPanel Margin="14">
                    <TextBlock Text="Deploy plugin from repo" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Runs deploy.ps1 (backup-preserving). Steam should be closed for Millennium runtime updates."
                               Foreground="#9ca3af" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Repo root" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="RepoRootBox" Padding="8" Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                    </Grid>
                    <Button Content="Deploy Rewired plugin" Padding="14,8" HorizontalAlignment="Left" Click="Deploy_Click" />
                    <TextBox x:Name="DeployLogBox" Margin="0,12,0,0" MinHeight="200" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" IsReadOnly="True"
                             Background="#0b0e14" Foreground="#d1d5db" BorderBrush="#3b4557" Padding="8" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="Ready." Foreground="#9ca3af" Margin="0,10,0,0" />
    </Grid>
</Window>
