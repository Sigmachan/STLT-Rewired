<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Material You dark — Rewired cyan accent (#66c0f4) on M3 surfaces -->

    <Color x:Key="RewiredPrimaryColor">#66c0f4</Color>
    <Color x:Key="RewiredPrimaryContainerColor">#1a3a4f</Color>
    <Color x:Key="RewiredSurfaceColor">#141a21</Color>
    <Color x:Key="RewiredSurfaceContainerColor">#1c242d</Color>
    <Color x:Key="RewiredSurfaceContainerHighColor">#252f3a</Color>
    <Color x:Key="RewiredSurfaceContainerHighestColor">#2e3a47</Color>
    <Color x:Key="RewiredOutlineColor">#3d4f61</Color>
    <Color x:Key="RewiredOnSurfaceColor">#e8edf2</Color>
    <Color x:Key="RewiredOnSurfaceVariantColor">#9aa8b5</Color>
    <Color x:Key="RewiredSuccessColor">#7dd87a</Color>
    <Color x:Key="RewiredWarnColor">#f0b429</Color>

    <SolidColorBrush x:Key="SteamBgPrimary" Color="{StaticResource RewiredSurfaceColor}" />
    <SolidColorBrush x:Key="SteamBgDeep" Color="#0c1016" />
    <SolidColorBrush x:Key="SteamBgElevated" Color="{StaticResource RewiredSurfaceContainerColor}" />
    <SolidColorBrush x:Key="SteamBgInput" Color="{StaticResource RewiredSurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SteamBgSecondary" Color="{StaticResource RewiredSurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SteamAccent" Color="{StaticResource RewiredPrimaryColor}" />
    <SolidColorBrush x:Key="SteamAccentHover" Color="#8ed4ff" />
    <SolidColorBrush x:Key="SteamBorder" Color="{StaticResource RewiredOutlineColor}" />
    <SolidColorBrush x:Key="SteamBorderSubtle" Color="#2a3542" />
    <SolidColorBrush x:Key="SteamTextPrimary" Color="{StaticResource RewiredOnSurfaceColor}" />
    <SolidColorBrush x:Key="SteamTextSecondary" Color="#b8c4cf" />
    <SolidColorBrush x:Key="SteamTextMuted" Color="{StaticResource RewiredOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="SteamSuccess" Color="{StaticResource RewiredSuccessColor}" />
    <SolidColorBrush x:Key="SteamWarn" Color="{StaticResource RewiredWarnColor}" />
    <SolidColorBrush x:Key="RewiredPrimaryContainerBrush" Color="{StaticResource RewiredPrimaryContainerColor}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SteamBgPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="FontFamily" Value="{materialDesign:MaterialDesignFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="RewiredPrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20" />
        <Setter Property="Padding" Value="22,10" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="RewiredGhostButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
    </Style>

    <Style x:Key="RewiredPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SteamBgElevated}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1" />
    </Style>

    <Style x:Key="RewiredCard" TargetType="Border" BasedOn="{StaticResource RewiredPanel}">
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="MinHeight" Value="96" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        <Setter Property="Background" Value="{StaticResource SteamBgSecondary}" />
    </Style>

    <Style x:Key="RewiredSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="RewiredPageSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,24" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="RewiredSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="RewiredFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="Margin" Value="4,0,0,6" />
    </Style>

    <Style x:Key="RewiredStatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextMuted}" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style x:Key="RewiredStatValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
    </Style>

    <Style x:Key="RewiredNavItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="12,3" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="28"
                            Padding="18,12" Margin="0,1">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SteamBgSecondary}" />
                            <Setter Property="Foreground" Value="{StaticResource SteamTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource RewiredPrimaryContainerBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource SteamAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RewiredNavList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource RewiredNavItem}" />
    </Style>

    <Style x:Key="RewiredLogBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
    </Style>

    <Style x:Key="RewiredSidebar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SteamBgDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource SteamBorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style x:Key="RewiredBrandTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SteamAccent}" />
    </Style>

</ResourceDictionary>
