<Window x:Class="RewiredManager.App.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set up Rewired" Height="520" Width="640" MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanMinimize"
        Background="#10131a" Foreground="#f3f4f6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Set up Rewired" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="One app installs unlock, in-Steam UI, and plugin — like LuaTools Gen2, clean-room."
                       Foreground="#9ca3af" TextWrapping="Wrap" Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Steam folder" Foreground="#cbd5e1" Margin="0,0,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SteamPathBox" Padding="8" Background="#0b0e14" Foreground="#f3f4f6" BorderBrush="#3b4557" />
                <Button Grid.Column="1" Content="Detect" Margin="8,0,0,0" Padding="12,8" Click="DetectSteam_Click" />
            </Grid>
            <TextBlock x:Name="ReadinessText" TextWrapping="Wrap" Foreground="#9ca3af" Margin="0,10,0,0" />

            <CheckBox x:Name="InstallUiCheck" Content="Install in-Steam UI (Millennium + Rewired plugin)" Margin="0,14,0,0"
                      Foreground="#e5e7eb" IsChecked="True" />
            <CheckBox x:Name="InstallOstCheck" Content="Install OpenSteamTool (unlock backend)" Margin="0,6,0,0"
                      Foreground="#e5e7eb" IsChecked="True" />
            <CheckBox x:Name="ShortcutCheck" Content="Create Desktop shortcut" Margin="0,6,0,0"
                      Foreground="#e5e7eb" IsChecked="True" />
        </StackPanel>

        <Border Grid.Row="2" Background="#0b0e14" BorderBrush="#3b4557" BorderThickness="1" CornerRadius="8" Padding="10">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" TextWrapping="Wrap" Foreground="#d1d5db" FontFamily="Consolas" FontSize="12" />
            </ScrollViewer>
        </Border>

        <WrapPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right">
            <Button Content="Close" Padding="14,8" Margin="0,0,8,0" Click="Close_Click" />
            <Button x:Name="RunButton" Content="Install Rewired" Padding="14,8" FontWeight="SemiBold" Click="RunSetup_Click" />
        </WrapPanel>
    </Grid>
</Window>
